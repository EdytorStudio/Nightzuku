#!/system/bin/sh
# TAPI - Termux API bridge for Nightzuku
# All commands use absolute /system/bin/ paths to avoid PATH issues on Android 13+.

ANDROID_BIN=/system/bin
PM="$ANDROID_BIN/pm"
UNZIP="$ANDROID_BIN/unzip"
GETPROP="$ANDROID_BIN/getprop"
APP_PROCESS="$ANDROID_BIN/app_process"
MKDIR="$ANDROID_BIN/mkdir"
CHMOD="$ANDROID_BIN/chmod"
MV="$ANDROID_BIN/mv"
RM="$ANDROID_BIN/rm"
MKTEMP="$ANDROID_BIN/mktemp"

[ -z "$HOME" ] && HOME=/data/local/tmp
TAPI_DIR="$HOME/.tapi"
DEX="$TAPI_DIR/rish_shizuku.dex"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -f "$DEX" ]; then
  "$MKDIR" -p "$TAPI_DIR"
  local_dex="$SCRIPT_DIR/tapi.dex"
  if [ -f "$local_dex" ]; then
    cp "$local_dex" "$DEX" 2>/dev/null || "$MV" "$local_dex" "$DEX" 2>/dev/null
  fi
fi

if [ ! -f "$DEX" ]; then
  apk_path=$("$PM" path kerneldroid.nightzuku 2>/dev/null)
  case "$apk_path" in
    package:*) apk_path="${apk_path#package:}" ;;
  esac
  if [ -z "$apk_path" ]; then
    apk_path=$("$PM" path kerneldroid.nightzuku 2>&1)
    case "$apk_path" in
      package:*) apk_path="${apk_path#package:}" ;;
    esac
  fi
  if [ -f "$apk_path" ]; then
    tmpdir=$("$MKTEMP" -d -p "$TAPI_DIR" 2>/dev/null || echo "$TAPI_DIR/tmp_$$")
    "$MKDIR" -p "$tmpdir" 2>/dev/null
    "$UNZIP" -o "$apk_path" "assets/rish_shizuku.dex" -d "$tmpdir" 2>/dev/null
    if [ -f "$tmpdir/assets/rish_shizuku.dex" ]; then
      "$MV" "$tmpdir/assets/rish_shizuku.dex" "$DEX"
    fi
    "$RM" -rf "$tmpdir"
  fi
fi

if [ ! -f "$DEX" ]; then
  echo "tapi: Cannot find rish_shizuku.dex" >&2
  echo "Make sure Nightzuku is installed." >&2
  echo "tapi: PM=$PM APK=$apk_path" >&2
  exit 1
fi

sdk=$("$GETPROP" ro.build.version.sdk 2>/dev/null)
case "$sdk" in
  3[4-9]|4[0-9]) "$CHMOD" 400 "$DEX" 2>/dev/null ;;
esac

export RISH_APPLICATION_ID="com.termux"
unset LD_LIBRARY_PATH

FIRST_ARG="${1:-}"

case "$FIRST_ARG" in
  --help|-h)
    exec "$APP_PROCESS" -Djava.class.path="$DEX" /system/bin --nice-name=tapi-manager rikka.shizuku.shell.TapiManager "$@"
    ;;
  nightzuku|status|start|stop|grant|revoke|modules|--modules)
    exec "$APP_PROCESS" -Djava.class.path="$DEX" /system/bin --nice-name=tapi-manager rikka.shizuku.shell.TapiManager "$@"
    ;;
  *)
    exec "$APP_PROCESS" -Djava.class.path="$DEX" /system/bin --nice-name=tapi rikka.shizuku.shell.ShizukuShellLoader "$@"
    ;;
esac
